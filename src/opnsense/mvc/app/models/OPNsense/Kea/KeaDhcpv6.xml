<model>
    <mount>//OPNsense/Kea/dhcp6</mount>
    <version>1.0.0</version>
    <description>Kea DHCPv6 configuration</description>
    <items>
        <general>
            <enabled type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </enabled>
            <manual_config type="BooleanField"/>
            <interfaces type="InterfaceField">
                <Multiple>Y</Multiple>
            </interfaces>
            <valid_lifetime type="IntegerField">
                <Default>4000</Default>
                <Required>Y</Required>
            </valid_lifetime>
            <fwrules type="BooleanField">
                <Required>Y</Required>
                <Default>1</Default>
            </fwrules>
        </general>
        <lexpire>
            <hold_reclaimed_time type="IntegerField">
                <MinimumValue>0</MinimumValue>
            </hold_reclaimed_time>
            <reclaim_timer_wait_time type="IntegerField">
                <MinimumValue>1</MinimumValue>
            </reclaim_timer_wait_time>
            <flush_reclaimed_timer_wait_time type="IntegerField">
                <MinimumValue>0</MinimumValue>
            </flush_reclaimed_timer_wait_time>
            <max_reclaim_time type="IntegerField">
                <MinimumValue>0</MinimumValue>
            </max_reclaim_time>
            <max_reclaim_leases type="IntegerField">
                <MinimumValue>0</MinimumValue>
            </max_reclaim_leases>
            <unwarned_reclaim_cycles type="IntegerField">
                <MinimumValue>0</MinimumValue>
            </unwarned_reclaim_cycles>
        </lexpire>
        <ha>
            <enabled type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </enabled>
            <this_server_name type="TextField">
                <Mask>/^([0-9a-zA-Z.\:\-,_]){0,1024}$/u</Mask>
            </this_server_name>
            <max_unacked_clients type="IntegerField">
                <MinimumValue>0</MinimumValue>
                <MaximumValue>65535</MaximumValue>
                <Default>2</Default>
                <Required>Y</Required>
            </max_unacked_clients>
        </ha>
        <subnets>
            <subnet6 type="ArrayField">
                <subnet type="NetworkField">
                    <NetMaskRequired>Y</NetMaskRequired>
                    <AddressFamily>ipv6</AddressFamily>
                    <Required>Y</Required>
                    <Constraints>
                        <check001>
                            <type>UniqueConstraint</type>
                            <ValidationMessage>Subnet must be unique.</ValidationMessage>
                        </check001>
                    </Constraints>
                </subnet>
                <allocator type="OptionField">
                    <BlankDesc>Default</BlankDesc>
                    <OptionValues>
                        <iterative>iterative</iterative>
                        <random>random</random>
                    </OptionValues>
                </allocator>
                <pd-allocator type="OptionField">
                    <BlankDesc>Default</BlankDesc>
                    <OptionValues>
                        <iterative>iterative</iterative>
                        <random>random</random>
                        <flq>Free Lease Queue Allocator</flq>
                    </OptionValues>
                </pd-allocator>
                <option_data>
                    <dns_servers type="NetworkField">
                        <NetMaskAllowed>N</NetMaskAllowed>
                        <AddressFamily>ipv6</AddressFamily>
                        <AsList>Y</AsList>
                    </dns_servers>
                    <domain_search type="HostnameField">
                        <IpAllowed>N</IpAllowed>
                        <AsList>Y</AsList>
                        <ValidationMessage>Please specify a valid list of domains.</ValidationMessage>
                    </domain_search>
                    <v6_dnr type="TextField">
                        <Mask>/^([^\n"])*$/u</Mask>
                    </v6_dnr>
                </option_data>
                <option type="ModelRelationField">
                    <Model>
                        <options>
                            <source>OPNsense.Kea.KeaDhcpv6</source>
                            <items>options.option</items>
                            <display>description</display>
                        </options>
                    </Model>
                    <Multiple>Y</Multiple>
                </option>
                <pools type=".\KeaPoolsField">
                </pools>
                <interface type="InterfaceField">
                    <Required>Y</Required>
                </interface>
                <ddns_forward_zone type="HostnameField">
                    <IpAllowed>N</IpAllowed>
                    <Constraints>
                        <check001>
                            <ValidationMessage>Forward zone and DNS server must either both be set or left empty.</ValidationMessage>
                            <type>DependConstraint</type>
                            <addFields>
                                <field1>ddns_dns_server</field1>
                            </addFields>
                        </check001>
                    </Constraints>
                </ddns_forward_zone>
                <ddns_dns_server type="NetworkField">
                    <NetMaskAllowed>N</NetMaskAllowed>
                    <Constraints>
                        <check001>
                            <ValidationMessage>Forward zone and DNS server must either both be set or left empty.</ValidationMessage>
                            <type>DependConstraint</type>
                            <addFields>
                                <field1>ddns_forward_zone</field1>
                            </addFields>
                        </check001>
                    </Constraints>
                </ddns_dns_server>
                <ddns_domain_key_name type="TextField">
                    <Constraints>
                        <check001>
                            <ValidationMessage>TSIG name and secret must either both be set or left empty.</ValidationMessage>
                            <type>DependConstraint</type>
                            <addFields>
                                <field1>ddns_domain_key_secret</field1>
                            </addFields>
                        </check001>
                    </Constraints>
                </ddns_domain_key_name>
                <ddns_domain_key_secret type="Base64Field">
                    <Constraints>
                        <check001>
                            <ValidationMessage>TSIG name and secret must either both be set or left empty.</ValidationMessage>
                            <type>DependConstraint</type>
                            <addFields>
                                <field1>ddns_domain_key_name</field1>
                            </addFields>
                        </check001>
                    </Constraints>
                </ddns_domain_key_secret>
                <ddns_domain_key_algorithm type="OptionField">
                    <OptionValues>
                        <hmac-md5>hmac-md5</hmac-md5>
                        <hmac-sha1>hmac-sha1</hmac-sha1>
                        <hmac-sha224>hmac-sha224</hmac-sha224>
                        <hmac-sha256>hmac-sha256</hmac-sha256>
                        <hmac-sha384>hmac-sha384</hmac-sha384>
                        <hmac-sha512>hmac-sha512</hmac-sha512>
                    </OptionValues>
                    <Constraints>
                        <check001>
                            <ValidationMessage>An algorithm is required if a TSIG secret is set.</ValidationMessage>
                            <type>DependConstraint</type>
                            <addFields>
                                <field1>ddns_domain_key_secret</field1>
                            </addFields>
                        </check001>
                    </Constraints>
                </ddns_domain_key_algorithm>
                <description type="DescriptionField"/>
            </subnet6>
        </subnets>
        <reservations>
            <reservation type="ArrayField">
                <subnet type="ModelRelationField">
                    <Model>
                        <subnets>
                            <source>OPNsense.Kea.KeaDhcpv6</source>
                            <items>subnets.subnet6</items>
                            <display>subnet</display>
                        </subnets>
                    </Model>
                    <ValidationMessage>Related subnet not found.</ValidationMessage>
                    <Constraints>
                        <check001>
                            <reference>duid.check001</reference>
                        </check001>
                    </Constraints>
                    <Required>Y</Required>
                </subnet>
                <ip_address type="NetworkField">
                    <NetMaskAllowed>N</NetMaskAllowed>
                    <AddressFamily>ipv6</AddressFamily>
                    <Constraints>
                        <check001>
                            <ValidationMessage>Duplicate entry exists.</ValidationMessage>
                            <type>UniqueConstraint</type>
                        </check001>
                    </Constraints>
                </ip_address>
                <duid type="TextField">
                    <Mask>/^(?:[0-9A-Fa-f]{2}(?::[0-9A-Fa-f]{2})+)$/</Mask>
                    <ValidationMessage>Value must be a colon-separated hexadecimal sequence (e.g., 01:02:f3).</ValidationMessage>
                    <Constraints>
                        <check001>
                            <ValidationMessage>Duplicate entry exists.</ValidationMessage>
                            <type>UniqueConstraint</type>
                            <addFields>
                                <field1>subnet</field1>
                            </addFields>
                        </check001>
                    </Constraints>
                </duid>
                <hw_address type="MacAddressField">
                    <Constraints>
                        <check001>
                            <ValidationMessage>Duplicate entry exists.</ValidationMessage>
                            <type>UniqueConstraint</type>
                            <caseInsensitive>Y</caseInsensitive>
                            <addFields>
                                <field1>subnet</field1>
                            </addFields>
                        </check001>
                    </Constraints>
                </hw_address>
                <hostname type="HostnameField">
                    <IsDNSName>Y</IsDNSName>
                </hostname>
                <domain_search type="HostnameField">
                    <IpAllowed>N</IpAllowed>
                    <AsList>Y</AsList>
                    <ValidationMessage>Please specify a valid list of domains.</ValidationMessage>
                </domain_search>
                <option type="ModelRelationField">
                    <Model>
                        <options>
                            <source>OPNsense.Kea.KeaDhcpv6</source>
                            <items>options.option</items>
                            <display>description</display>
                        </options>
                    </Model>
                    <Multiple>Y</Multiple>
                </option>
                <description type="DescriptionField"/>
            </reservation>
        </reservations>
        <options>
            <option type="ArrayField">
                <code type="JsonKeyValueStoreField">
                    <Required>Y</Required>
                    <ConfigdPopulateAct>kea list dhcp_options6</ConfigdPopulateAct>
                    <OptionValues>
                        <!-- mock option groups returned by JSON -->
                        <optgroup1>Assigned</optgroup1>
                        <optgroup2>Unassigned</optgroup2>
                    </OptionValues>
                </code>
                <encoding type="OptionField">
                    <Required>Y</Required>
                    <Default>hex</Default>
                    <OptionValues>
                        <hex>hex</hex>
                        <ipv4-address>IPv4 address</ipv4-address>
                        <ipv6-address>IPv6 address</ipv6-address>
                        <uint8>uint8</uint8>
                        <uint16>uint16</uint16>
                        <uint32>uint32</uint32>
                        <int32>int32</int32>
                        <boolean>bool</boolean>
                        <string>string</string>
                        <fqdn>FQDN</fqdn>
                    </OptionValues>
                </encoding>
                <data type=".\KeaOptionDataField">
                    <CodeSource>code</CodeSource>
                    <EncodingSource>encoding</EncodingSource>
                    <OptionSpace>dhcp6</OptionSpace>
                    <Required>Y</Required>
                </data>
                <force type="BooleanField"/>
                <match_code type="JsonKeyValueStoreField">
                    <ConfigdPopulateAct>kea list dhcp_options6</ConfigdPopulateAct>
                    <OptionValues>
                        <!-- mock option groups returned by JSON -->
                        <optgroup1>Assigned</optgroup1>
                        <optgroup2>Unassigned</optgroup2>
                    </OptionValues>
                    <Constraints>
                        <check001>
                            <ValidationMessage>Match code and match data must either both be set or left empty.</ValidationMessage>
                            <type>DependConstraint</type>
                            <addFields>
                                <field1>match_data</field1>
                            </addFields>
                        </check001>
                    </Constraints>
                </match_code>
                <match_encoding type="OptionField">
                    <OptionValues>
                        <hex>hex</hex>
                        <ipv4-address>IPv4 address</ipv4-address>
                        <ipv6-address>IPv6 address</ipv6-address>
                        <uint8>uint8</uint8>
                        <uint16>uint16</uint16>
                        <uint32>uint32</uint32>
                        <int32>int32</int32>
                        <boolean>bool</boolean>
                        <string>string</string>
                        <fqdn>FQDN</fqdn>
                    </OptionValues>
                    <Constraints>
                        <check001>
                            <ValidationMessage>Field is required when match data is set.</ValidationMessage>
                            <type>DependConstraint</type>
                            <addFields>
                                <field1>match_data</field1>
                            </addFields>
                        </check001>
                    </Constraints>
                </match_encoding>
                <match_data type=".\KeaOptionDataField">
                    <CodeSource>match_code</CodeSource>
                    <EncodingSource>match_encoding</EncodingSource>
                    <OptionSpace>dhcp6</OptionSpace>
                    <Constraints>
                        <check001>
                            <ValidationMessage>Match code and match data must either both be set or left empty.</ValidationMessage>
                            <type>SetConstraint</type>
                            <addFields>
                                <field1>match_code</field1>
                            </addFields>
                        </check001>
                    </Constraints>
                </match_data>
                <description type="DescriptionField">
                    <Required>Y</Required>
                    <Constraints>
                        <check001>
                            <ValidationMessage>Description must be unique.</ValidationMessage>
                            <type>UniqueConstraint</type>
                        </check001>
                    </Constraints>
                </description>
            </option>
        </options>
        <pd_pools>
            <pd_pool type="ArrayField">
                <subnet type="ModelRelationField">
                    <Model>
                        <subnets>
                            <source>OPNsense.Kea.KeaDhcpv6</source>
                            <items>subnets.subnet6</items>
                            <display>subnet</display>
                        </subnets>
                    </Model>
                    <ValidationMessage>Related subnet not found.</ValidationMessage>
                    <Required>Y</Required>
                </subnet>
                <prefix type="NetworkField">
                    <AddressFamily>ipv6</AddressFamily>
                </prefix>
                <prefix_len type="IntegerField">
                    <MinimumValue>1</MinimumValue>
                    <MaximumValue>128</MaximumValue>
                    <Default>56</Default>
                    <Required>Y</Required>
                </prefix_len>
                <delegated_len type="IntegerField">
                    <MinimumValue>1</MinimumValue>
                    <MaximumValue>128</MaximumValue>
                    <Required>Y</Required>
                    <Default>64</Default>
                </delegated_len>
                <description type="DescriptionField"/>
            </pd_pool>
        </pd_pools>
        <ha_peers>
            <peer type="ArrayField">
                <name type="TextField">
                    <Required>Y</Required>
                    <Constraints>
                        <check001>
                            <ValidationMessage>Duplicate entry exists.</ValidationMessage>
                            <type>UniqueConstraint</type>
                        </check001>
                    </Constraints>
                </name>
                <role type="OptionField">
                    <Default>primary</Default>
                    <Required>Y</Required>
                    <OptionValues>
                        <primary>primary</primary>
                        <standby>standby</standby>
                    </OptionValues>
                </role>
                <url type="UrlField">
                    <Required>Y</Required>
                    <Constraints>
                        <check001>
                            <ValidationMessage>Duplicate entry exists.</ValidationMessage>
                            <type>UniqueConstraint</type>
                        </check001>
                    </Constraints>
                </url>
            </peer>
        </ha_peers>
    </items>
</model>
