<model>
    <mount>/gateways/gateway_group+</mount>
    <version>1.0.0</version>
    <description>Gateway group configuration</description>
    <items>
        <gateway_group type="ArrayField">
            <name type="TextField">
                <Required>Y</Required>
                <ValidationMessage>A valid group name must be specified. The name may only consist of the characters "a-zA-Z0-9_" and must be less than 32 characters long.</ValidationMessage>
                <Mask>/^[a-zA-Z0-9_\-]{1,32}$/</Mask>
                <Constraints>
                    <check001>
                        <type>UniqueConstraint</type>
                        <ValidationMessage>Gateway group with this name already exists.</ValidationMessage>
                    </check001>
                </Constraints>
            </name>
            <item2 type=".\GatewayGroupItemField"/>
            <item3 type=".\GatewayGroupItemField"/>
            <item4 type=".\GatewayGroupItemField"/>
            <item5 type=".\GatewayGroupItemField"/>
            <!-- <item> placed last to assist inline migration -->
            <item type=".\GatewayGroupItemField"/>
            <trigger type="OptionField">
                <OptionValues>
                    <down>Member Down</down>
                    <downloss>Packet Loss</downloss>
                    <downlatency>High Latency</downlatency>
                    <downlosslatency>Packet Loss and High Latency</downlosslatency>
                </OptionValues>
            </trigger>
            <poolopts type="OptionField">
                <OptionValues>
                    <default value="">Default</default>
                    <roundrobin value="round-robin">Round Robin</roundrobin>
                    <roundrobinsticky value="round-robin sticky-address">Round Robin with Sticky Address</roundrobinsticky>
                </OptionValues>
            </poolopts>
            <descr type="DescriptionField"/>
        </gateway_group>
    </items>
</model>
