<form>
    <field>
        <id>gateway_group.name</id>
        <label>Name</label>
        <type>text</type>
    </field>
    <field>
        <id>gateway_group.gateways</id>
        <type>hidden</type>
        <label>Gateways</label>
        <grid_view>
            <formatter>gateways</formatter>
        </grid_view>
    </field>
    <field>
        <id>gateway_group.item</id>
        <label>Tier 1</label>
        <type>select_multiple</type>
        <style>selectpicker</style>
        <grid_view>
            <visible>false</visible>
        </grid_view>
    </field>
    <field>
        <id>gateway_group.item2</id>
        <label>Tier 2</label>
        <type>select_multiple</type>
        <grid_view>
            <visible>false</visible>
        </grid_view>
    </field>
    <field>
        <id>gateway_group.item3</id>
        <label>Tier 3</label>
        <type>select_multiple</type>
        <grid_view>
            <visible>false</visible>
        </grid_view>
    </field>
    <field>
        <id>gateway_group.item4</id>
        <label>Tier 4</label>
        <type>select_multiple</type>
        <grid_view>
            <visible>false</visible>
        </grid_view>
    </field>
    <field>
        <id>gateway_group.item5</id>
        <label>Tier 5</label>
        <type>select_multiple</type>
        <grid_view>
            <visible>false</visible>
        </grid_view>
    </field>
    <field>
        <id>gateway_group.trigger</id>
        <label>Trigger Level</label>
        <type>dropdown</type>
        <help>When to trigger exclusion of a member</help>
    </field>
    <field>
        <id>gateway_group.poolopts</id>
        <label>Pool Options</label>
        <type>dropdown</type>
        <help>
            Default: Round Robin, Sticky Address determined by advanced settings
            Round Robin: Loops through the translation addresses.
            Sticky Address: The Sticky Address option can be used with the Round Robin pool type to ensure that a particular source address is always mapped to the same translation address.
        </help>
    </field>
    <field>
        <id>gateway_group.descr</id>
        <label>Description</label>
        <type>text</type>
        <help>You may enter a description here for your reference (not parsed). </help>
    </field>
</form>
